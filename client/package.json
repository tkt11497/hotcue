{
  "name": "gcn-voice-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "cap:build": "vite build && npx cap sync",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "hosting:deploy": "npm run build && npx firebase-tools deploy --only hosting --config firebase.json",
    "hosting:preview": "npm run build && npx firebase-tools hosting:channel:deploy preview --config firebase.json"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capawesome-team/capacitor-android-foreground-service": "^8.0.1",
    "firebase": "^12.10.0",
    "html5-qrcode": "^2.3.8",
    "qrcode": "^1.5.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  }
}
