<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp"
    android:gravity="center_vertical">

    <!-- App title -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GCN Voice"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Status / room name -->
    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Not in a call"
        android:textColor="#AAffffff"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

        <!-- Mute / Unmute button -->
        <FrameLayout
            android:id="@+id/widget_mute_btn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/widget_btn_mute"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/widget_mute_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🎙"
                android:textSize="18sp" />
        </FrameLayout>

        <!-- Hang Up button -->
        <FrameLayout
            android:id="@+id/widget_hangup_btn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/widget_btn_hangup"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textColor="#FFEF4444"
                android:textSize="18sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Open App button (always visible) -->
        <FrameLayout
            android:id="@+id/widget_open_btn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/widget_btn_join"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="▶"
                android:textColor="#FF22C55E"
                android:textSize="18sp" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
